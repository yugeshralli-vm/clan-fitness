# Postgres (Vercel Postgres / Neon connection string)
DATABASE_URL=

# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Web Push (generate with `npx web-push generate-vapid-keys`)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@example.com

# Email notifications (https://resend.com/api-keys)
RESEND_API_KEY=
RESEND_FROM_EMAIL="Clan Fitness <onboarding@resend.dev>"

# Absolute base URL used to build links inside emails (no trailing slash)
APP_URL=http://localhost:3000

# Admin dashboard (/admin) — Clerk user id of the one account allowed to access it
ADMIN_USER_ID=
